# Copy to `.env` and fill in values. Never commit real secrets.

# Required: Sunbird AI API bearer token from https://api.sunbird.ai/
SUNBIRD_API_TOKEN=

# Optional: URL of the FastAPI backend (Streamlit `app.py` only)
# Default when unset: http://127.0.0.1:8000
# On Hugging Face Docker Spaces, leave unset so Streamlit uses the default
# (FastAPI runs on 127.0.0.1:8000 inside the same container).
BACKEND_URL=http://127.0.0.1:8000

# Hugging Face Space: add this exact name under Settings → Variables and secrets
# (Repository secrets / Space secrets). The backend will not work without it.
