# Copy to `.env` and fill in values. Never commit real secrets.

# Required: Sunbird AI API bearer token from https://api.sunbird.ai/
SUNBIRD_API_TOKEN=

# Optional: URL of the FastAPI backend (Streamlit `app.py` only)
# Default: http://127.0.0.1:8000
#
# Do NOT set this to your public Hugging Face Space URL (https://*.hf.space).
# From inside the Space container, Streamlit must call FastAPI on 127.0.0.1:8000.
# The bundled start.sh forces BACKEND_URL for Docker; local two-terminal setups
# should still use http://127.0.0.1:8000 unless the API runs elsewhere.
BACKEND_URL=http://127.0.0.1:8000

# Optional: Streamlit waits this many seconds for each /pipeline request (default 1800).
# PIPELINE_HTTP_TIMEOUT=1800

# Hugging Face Space: add this exact name under Settings → Variables and secrets
# (Repository secrets / Space secrets). The backend will not work without it.
